# --- Ma'lumotlar bazasi (PostgreSQL) ---
# Lokal ishlab chiqish (docker-compose.yml, host port 5434):
DATABASE_URL="postgresql://vagon:vagon@localhost:5434/vagon_db?schema=public"

# --- Autentifikatsiya (Auth.js) ---
# Generatsiya: npx auth secret   yoki   openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_RANDOM_SECRET"
AUTH_URL="http://localhost:3000"

# --- Ilova ---
NODE_ENV="development"
